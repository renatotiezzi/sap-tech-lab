# =============================================================================
# CR51 - SRV (ZSB_Q2C_ARQ_MGR_V2) - Test Requests
# =============================================================================
#
# ATENÇÃO: ESSE SERVIÇO É ODATA V2
# A URL visível no Gateway Client é:
#   /sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2/ArqMgr
#
# =============================================================================
# OPÇÃO A — SAP GATEWAY CLIENT (/IWFND/GW_CLIENT) no SAP GUI
# =============================================================================
#
# ---- PARA CRIAR (POST) ----
#   HTTP Method : POST
#   URI         : /sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2/ArqMgr
#   Header      : Content-Type = application/json
#   Body        : ver bloco "POST" abaixo
#
# ---- PARA MODIFICAR (MERGE) ----
#   HTTP Method : MERGE          ← EM V2 O UPDATE É MERGE, NÃO PATCH
#   URI         : /sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')
#   Header 1    : Content-Type = application/json
#   Header 2    : If-Match = *   ← OBRIGATÓRIO — sem isso retorna 405/412
#   Body        : ver bloco "MERGE" abaixo
#
# ---- PARA CHAMAR ACTION (POST) ----
#   HTTP Method : POST
#   URI         : /sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2/Reprocess?Pedido='PED-TEST-010'&Bandeira='Volks'
#   Header      : Content-Type = application/json
#
# =============================================================================
# OPÇÃO B — VS Code REST Client (extensão: REST Client de Huachao Mao)
#   Ctrl+Shift+X → buscar "REST Client" → Install
#   Preencha @host, @user, @pass abaixo e clique "Send Request"
# =============================================================================

@host = https://<SEU-HOST>
@user = <USUARIO>
@pass = <SENHA>
@base = {{host}}/sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2

# =============================================================================
# 1. GET - Listar registros
# =============================================================================

GET {{base}}/ArqMgr?$top=10&$orderby=Datum desc
Authorization: Basic {{user}} {{pass}}
Accept: application/json

###

# =============================================================================
# 2. GET - Ler um registro específico
# =============================================================================

GET {{base}}/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')
Authorization: Basic {{user}} {{pass}}
Accept: application/json

###

# =============================================================================
# 3. POST - Criar registro com deep insert do Log
# =============================================================================
# Gateway Client: HTTP Method = POST
#                 URI         = /sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2/ArqMgr
#                 Header      : Content-Type = application/json
# =============================================================================

POST {{base}}/ArqMgr
Authorization: Basic {{user}} {{pass}}
Content-Type: application/json

{
  "Pedido":    "PED-TEST-010",
  "Bandeira":  "Volks",
  "TipoDoc":   "NF",
  "CabecArq":  "HEADER::NF::006",
  "Conteudo":  "{\"pedido\":\"PED-TEST-006\",\"bandeira\":\"VISA\",\"valor\":1500.00,\"itens\":[{\"sku\":\"SKU-A\",\"qtd\":2}]}",
  "to_Log": {
    "IdRef":    "001",
    "Etapa":    "PROCESSAMENTO",
    "Mensagem": "Erro ao criar SalesOrder"
  }
}

###

# =============================================================================
# 4. MERGE - Modificar campos do registro  ← EM V2 O UPDATE É MERGE
# =============================================================================
# Gateway Client: HTTP Method = MERGE
#                 URI         = /sap/opu/odata/sap/ZSB_Q2C_ARQ_MGR_V2/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')
#                 Header 1    : Content-Type = application/json
#                 Header 2    : If-Match = *   ← OBRIGATÓRIO
# =============================================================================

MERGE {{base}}/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')
Authorization: Basic {{user}} {{pass}}
Content-Type: application/json
If-Match: *

{
  "Status":     "PENDENTE",
  "Tentativas": "0"
}

###

# =============================================================================
# 5. MERGE - Reabrir registro com conteúdo corrigido
# =============================================================================

MERGE {{base}}/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')
Authorization: Basic {{user}} {{pass}}
Content-Type: application/json
If-Match: *

{
  "Status":   "PENDENTE",
  "Conteudo": "{\"pedido\":\"PED-TEST-006\",\"bandeira\":\"VISA\",\"valor\":1500.00,\"itens\":[{\"sku\":\"SKU-A\",\"qtd\":3}]}"
}

###

# =============================================================================
# 6. POST - Action Reprocess
# =============================================================================

POST {{base}}/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')/Reprocess
Authorization: Basic {{user}} {{pass}}
Content-Type: application/json

{}

###

# =============================================================================
# 7. POST - Action Cancel
# =============================================================================

POST {{base}}/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')/Cancel
Authorization: Basic {{user}} {{pass}}
Content-Type: application/json

{}

###

# =============================================================================
# 8. DELETE - Remover registro (e log filho via composição)
# =============================================================================

DELETE {{base}}/ArqMgr(Pedido='PED-TEST-010',Bandeira='Volks')
Authorization: Basic {{user}} {{pass}}
If-Match: *
