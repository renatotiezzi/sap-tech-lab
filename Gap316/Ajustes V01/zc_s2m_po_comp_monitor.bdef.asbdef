projection;
strict ( 2 );
use draft;
use side effects;

define behavior for ZC_S2M_PO_COMP_MONITOR
{

  use association _Materiais { with draft; }

  use update;

  /* RTiezzi: obrigatório com strict + use draft na projeção */
  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

}

define behavior for ZC_S2M_MATERIAIS_COMPATIVEIS
{
  use association _Componente { with draft; }

  use action Remarcar;
  use update;

}
